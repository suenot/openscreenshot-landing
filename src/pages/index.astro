---
const GITHUB = "https://github.com/suenot/openscreenshot";
const features = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>`,
    title: "Region capture",
    desc: "Drag to select any area of the screen. Dashed border with pixel dimensions shown live.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="8 12 12 16 16 12"/><line x1="12" y1="8" x2="12" y2="16"/></svg>`,
    title: "Auto downscale",
    desc: "Choose 1x, 1/2x, 1/4x or 1/8x. Result goes straight to clipboard — no files saved.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><circle cx="15.5" cy="8.5" r="1.5"/><circle cx="8.5" cy="15.5" r="1.5"/><circle cx="15.5" cy="15.5" r="1.5"/></svg>`,
    title: "Resize handles",
    desc: "After drawing, drag any of 8 corner/edge handles to fine-tune the selection.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M8 4v16M16 4v16M2 12h20"/></svg>`,
    title: "Global hotkey",
    desc: "⌘⇧6 by default. Change to any combo via Set Hotkey… in the menu bar.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>`,
    title: "Clipboard only",
    desc: "PNG lands in clipboard instantly. Paste into ChatGPT, Claude, Gemini — anywhere.",
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>`,
    title: "Menu bar app",
    desc: "Lives in the status bar. No Dock icon. Launches at login. Always ready.",
  },
];
const steps = [
  { step: "1", title: "Trigger", desc: "Press ⌘⇧6. A crosshair overlay appears instantly." },
  { step: "2", title: "Select", desc: "Drag to capture a region. Adjust handles. Press Enter." },
  { step: "3", title: "Paste", desc: "Downscaled PNG is in clipboard. Paste into your LLM." },
];
const scaleRows = [
  ["1x",     "3456 × 2234 px", "~12 MB", "~10,294", "~15.4¢"],
  ["1/2x",   "1728 × 1117 px", "~3 MB",  "~2,574", "~3.9¢"],
  ["1/2.5x", "1382 × 894 px",  "~1.8 MB", "~1,647", "~2.5¢"],
  ["1/3x",   "1152 × 745 px",  "~1.2 MB", "~1,144", "~1.7¢"],
  ["1/4x",   "864 × 559 px",   "~600 KB", "~644",   "~1.0¢"],
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OpenScreenshot — Screenshot tool for LLM context</title>
  <meta name="description" content="Capture screen regions and auto-downscale before sending to LLM. Stop overpaying for 4K screenshots." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    @import "../styles/global.css";
  </style>
</head>
<body class="bg-[#0a0a0f] text-white font-sans antialiased">

  <!-- NAV -->
  <nav class="fixed top-0 w-full z-50 border-b border-[#1e1e2e] bg-[#0a0a0f]/80 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-semibold text-white flex items-center gap-2">
        <img src="/favicon.svg" width="18" height="18" alt="Logo" />
        OpenScreenshot
      </span>
      <div class="flex items-center gap-6 text-sm text-gray-400">
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#how" class="hover:text-white transition-colors">How it works</a>
        <a href={GITHUB} target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="pt-40 pb-24 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-medium mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
        macOS 14+ · Free · Open Source
      </div>
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-6 leading-tight">
        Screenshots for<br/>
        <span class="text-indigo-400">LLM context.</span>
      </h1>
      <p class="text-lg text-gray-400 mb-10 max-w-xl mx-auto leading-relaxed">
        MacBook Retina produces 4K screenshots — that's expensive tokens.
        OpenScreenshot captures any region and downscales automatically,
        so you only pay for pixels that matter.
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href={GITHUB + "/releases"} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-500 hover:bg-indigo-400 text-white font-semibold rounded-xl transition-colors text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download for macOS
        </a>
        <a href={GITHUB} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-6 py-3 bg-[#13131a] hover:bg-[#1e1e2e] border border-[#1e1e2e] hover:border-[#2e2e3e] text-gray-300 font-semibold rounded-xl transition-colors text-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
      <p class="mt-8 text-base text-gray-600">
        Default hotkey <kbd class="px-2.5 py-1 rounded bg-[#1e1e2e] border border-[#2e2e3e] text-base text-gray-300 tracking-wide">Cmd+Shift+6</kbd> · fully customizable
      </p>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-4 px-6">
    <div class="max-w-4xl mx-auto grid sm:grid-cols-3 gap-4">
      {[
        { icon: "🖥️", title: "Retina = 4K pixels", desc: "MacBook Pro screenshots are up to 3456×2234 px by default." },
        { icon: "💸", title: "Expensive tokens", desc: "Vision models charge per tile. A full screenshot costs 10× more than needed." },
        { icon: "🎯", title: "Less is enough", desc: "Models understand UI at 800px just as well as at 4000px." },
      ].map(item => (
        <div class="bg-[#13131a] border border-[#1e1e2e] rounded-2xl p-6">
          <div class="text-3xl mb-3">{item.icon}</div>
          <div class="font-semibold mb-1 text-white">{item.title}</div>
          <div class="text-sm text-gray-500 leading-relaxed">{item.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-3">Everything you need</h2>
      <p class="text-gray-500 text-center mb-12 text-sm">Minimal, fast, native macOS.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {features.map(f => (
          <div class="bg-[#13131a] border border-[#1e1e2e] rounded-2xl p-6 flex gap-4">
            <div class="text-indigo-400 shrink-0 mt-0.5" set:html={f.icon} />
            <div>
              <div class="font-semibold mb-1">{f.title}</div>
              <div class="text-sm text-gray-500 leading-relaxed">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" class="py-20 px-6 bg-[#0d0d14]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-3">How it works</h2>
      <p class="text-gray-500 text-sm mb-14">Three steps, two seconds.</p>
      <div class="grid sm:grid-cols-3 gap-8 text-left">
        {steps.map(s => (
          <div class="relative pl-12">
            <div class="absolute left-0 top-0 w-8 h-8 rounded-full bg-indigo-500/10 border border-indigo-500/30 flex items-center justify-center text-indigo-400 font-bold text-sm">
              {s.step}
            </div>
            <div class="font-semibold mb-1">{s.title}</div>
            <div class="text-sm text-gray-500 leading-relaxed">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCALE TABLE -->
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-3">Scale presets</h2>
      <p class="text-gray-500 text-sm mb-10">Pick once, remembered forever.</p>
      <div class="bg-[#13131a] border border-[#1e1e2e] rounded-2xl overflow-hidden text-left">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[#1e1e2e]">
              <th class="px-6 py-3 text-gray-400 font-medium">Preset</th>
              <th class="px-6 py-3 text-gray-400 font-medium">MBP 16" (3456×2234)</th>
              <th class="px-6 py-3 text-gray-400 font-medium">File Size</th>
              <th class="px-6 py-3 text-gray-400 font-medium">Tokens (Opus)</th>
              <th class="px-6 py-3 text-gray-400 font-medium">Cost (Opus)</th>
            </tr>
          </thead>
          <tbody>
            {scaleRows.map(([preset, px, size, tokens, cost]) => (
              <tr class="border-b border-[#1e1e2e] last:border-0 hover:bg-white/5 transition-colors">
                <td class="px-6 py-3 font-mono text-indigo-400">{preset}</td>
                <td class="px-6 py-3 text-gray-300">{px}</td>
                <td class="px-6 py-3 text-gray-500">{size}</td>
                <td class="px-6 py-3 text-gray-500">{tokens}</td>
                <td class="px-6 py-3 text-emerald-400">{cost}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">Ready to save tokens?</h2>
      <p class="text-gray-500 text-sm mb-10">Free and open source. macOS 14+.</p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href={GITHUB + "/releases"} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-8 py-3.5 bg-indigo-500 hover:bg-indigo-400 text-white font-semibold rounded-xl transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download .dmg
        </a>
        <a href={GITHUB} target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#13131a] hover:bg-[#1e1e2e] border border-[#1e1e2e] text-gray-300 font-semibold rounded-xl transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-[#1e1e2e] py-8 px-6 text-center text-sm text-gray-600">
    <a href={GITHUB} target="_blank" rel="noopener" class="hover:text-gray-400 transition-colors">
      github.com/suenot/openscreenshot
    </a>
    <span class="mx-3">·</span>
    <span>macOS 14+ · Free · MIT License</span>
  </footer>

</body>
</html>
